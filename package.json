{
  "name": "studyluma",
  "version": "0.1.0",
  "description": "React Router SSR web application for the StudyLuma learning platform.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run node_modules/@chromatis/base/infra/scripts/devServer.ts",
    "build": "react-router build",
    "start": "node build/server/index.js",
    "check": "react-router typegen && tsc --noEmit && eslint . && bun run node_modules/@chromatis/base/infra/scripts/checkArchitectureBoundaries.ts",
    "db": "bun run node_modules/@chromatis/base/infra/scripts/db.ts",
    "db:reset": "bun run node_modules/@chromatis/base/infra/scripts/dbReset.ts",
    "db:deploy": "bun run node_modules/@chromatis/base/infra/scripts/dbDeploy.ts",
    "db:seed-demo": "bun run scripts/seedDemo.ts",
    "db:seed-demo:local": "bun run scripts/seedDemo.ts --local",
    "cf:dev": "bun run node_modules/@chromatis/base/infra/scripts/cfDev.ts",
    "cf:deploy": "bun run node_modules/@chromatis/base/infra/scripts/cfDeploy.ts",
    "cf:deploy:demo": "bun run scripts/cfDeployDemo.ts"
  },
  "dependencies": {
    "@chromatis/base": "git+https://github.com/ChromatisGit/personal-base-framework.git",
    "@react-router/node": "^7.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "clsx": "^2.1.1",
    "image-size": "^2.0.2",
    "lucide-react": "^0.462.0",
    "motion": "^12.39.0",
    "postgres": "^3.4.8",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router": "^7.0.0",
    "rehype-react": "^8.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sonner": "^2.0.7",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.1",
    "@react-router/dev": "^7.0.0",
    "@types/bun": "^1.3.8",
    "@types/node": "^20.19.32",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-plugin-boundaries": "^5.4.0",
    "knip": "^6.14.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "wrangler": "^4.92.0",
    "zod": "^4.3.6"
  }
}
